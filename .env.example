# Slaze Browser Extension — Configuration
# Copy this file to .env.local and customize for your environment

# ─────────────────────────────────────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Production: https://api.slaze.it.com/v1
# Development: http://localhost:8082/v1
API_BASE=https://api.slaze.it.com/v1

# Override API_BASE for development (set to DEV_API_BASE in background.js line 28)
# Uncomment to enable local backend
# API_BASE=http://localhost:8082/v1

# ─────────────────────────────────────────────────────────────────────────────
# BUILD CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Node environment (leave as production for extension builds)
NODE_ENV=production

# Build output directory (relative to project root)
BUILD_OUTPUT_DIR=chromium

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME / CHROME STORAGE DEFAULTS
# ─────────────────────────────────────────────────────────────────────────────

# These values are set by the background script on install via chrome.storage.local
# Users can override at runtime via popup settings — no need to set here
# Included for reference / documentation:

# Slaze API base URL (stored as chrome.storage.local.slaze_api_base)
# Set automatically by background.js during extension install
SLAZE_API_BASE=https://api.slaze.it.com/v1

# Authentication token (stored as chrome.storage.local.slaze_auth_token)
# Issued by /auth/token endpoint — auto-managed, do not hardcode
# SLAZE_AUTH_TOKEN=<server-issued-token>

# User anonymous hash (stored as chrome.storage.local.slaze_user_hash)
# Generated by background.js on install (random UUID)
# SLAZE_USER_HASH=<random-uuid-v4>

# Developer mode toggle (stored as chrome.storage.local.slaze_dev_mode)
# Enable network request logging in popup
# SLAZE_DEV_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# EXTENSION METADATA
# ─────────────────────────────────────────────────────────────────────────────

# Extension version (read from package.json — do not set here)
# EXT_VERSION=0.4.0

# Manifest version (set per platform — Chromium: 3, Firefox: 2)
# MANIFEST_VERSION=3

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM-SPECIFIC CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Firefox build: auto-generates manifest.json from chromium manifest.json
# No environment variable needed — uses build-firefox.mjs script
# To build: npm run build:firefox

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT / DEBUG
# ─────────────────────────────────────────────────────────────────────────────

# Enable verbose logging in build process
# DEBUG=slaze:*

# Cache TTL in milliseconds (default: 5 minutes = 300000 ms)
# Set in chromium/src/config.js — CACHE_TTL_MS
CACHE_TTL_MS=300000

# ─────────────────────────────────────────────────────────────────────────────
# SCRIPTS / RELEASE
# ─────────────────────────────────────────────────────────────────────────────

# Build output filename for vote-menu component
# SET IN: vite.config.js build.lib.fileName
VOTE_MENU_BUNDLE=slazeVoteMenuBundle.js

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
#
# Before releasing to Chrome Web Store or Firefox AMO:
#
# 1. Update API_BASE to production endpoint
#    Set: API_BASE=https://api.slaze.it.com/v1
#
# 2. Verify extension version in package.json
#    Update: "version": "x.y.z"
#
# 3. Update manifest.json version to match
#    Both chromium/manifest.json and firefox/manifest.json
#
# 4. Build production bundles:
#    npm run build           (Chromium: outputs slazeVoteMenuBundle.js)
#    npm run build:firefox   (Firefox: auto-generates manifest v2)
#
# 5. Test in browser:
#    Chromium: chrome://extensions → Load unpacked → select chromium/
#    Firefox:  about:debugging → Load Temporary Add-on → select firefox/manifest.json
#
# 6. Package for release:
#    Chromium: Zip chromium/ folder, upload to Chrome Web Store
#    Firefox: Zip firefox/ folder (or submit via AMO web form)
#
# 7. Verify host_permissions in manifest match API_BASE:
#    Prod APIs:  "https://api.slaze.it.com/*"
#    Dev APIs:   "http://localhost:8082/*"
