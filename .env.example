# Slaze — Production Environment Variables (template)
# Copy this file to .env and fill in your real values.

# ── Clerk Authentication ──────────────────────────────────────────────────────
# From: https://dashboard.clerk.com → API Keys
PLASMO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk sync host — companion website that shares auth state with the extension
PLASMO_PUBLIC_CLERK_SYNC_HOST=https://slaze.it.com

# Clerk Frontend API domain — added to manifest host_permissions
# Format: https://<app-slug>.clerk.accounts.dev
CLERK_FRONTEND_API=https://your-app.clerk.accounts.dev

# ── Chrome Extension CRX Public Key ───────────────────────────────────────────
# Set for production to get a stable extension ID. Leave empty for dev.
CRX_PUBLIC_KEY=

# ── Slaze API Request Signing ──────────────────────────────────────────────────
# Shared HMAC secret between extension and backend. Generate with:
#   openssl rand -hex 32
# Must match SLAZE_API_SECRET in the backend .env exactly.
PLASMO_PUBLIC_SLAZE_API_SECRET=

# ── Slaze API ─────────────────────────────────────────────────────────────────
PLASMO_PUBLIC_SLAZE_API_BASE=https://api.slaze.it.com/v1
