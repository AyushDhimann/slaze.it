{
  "extends": "plasmo/templates/tsconfig.base",
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "paths": {
      "~*": ["./src/*"]
    },
    "baseUrl": ".",
    "types": ["chrome"],
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "build"]
}
