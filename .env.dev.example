# Slaze — Development Environment Variables (template)
# Copy this file to .env.dev and fill in your real values.

# ── Clerk Authentication ──────────────────────────────────────────────────────
PLASMO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk sync host — local companion web app for development
PLASMO_PUBLIC_CLERK_SYNC_HOST=http://localhost:8090

# Clerk Frontend API domain
# Format: https://<app-slug>.clerk.accounts.dev
CLERK_FRONTEND_API=https://your-app.clerk.accounts.dev

# ── Chrome Extension CRX Public Key ───────────────────────────────────────────
CRX_PUBLIC_KEY=

# ── Slaze API Request Signing ──────────────────────────────────────────────────
PLASMO_PUBLIC_SLAZE_API_SECRET=

# ── Slaze API ─────────────────────────────────────────────────────────────────
PLASMO_PUBLIC_SLAZE_API_BASE=http://localhost:8082/v1
